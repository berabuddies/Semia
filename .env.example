# Sample environment for Semia.
# Copy to `.env` and fill in your credentials. `.env` is gitignored.
# DO NOT commit real keys. CI runs `gitleaks` against the full history.

# -----------------------------------------------------------------------------
# Provider selection
# -----------------------------------------------------------------------------
# Two HTTP wire formats and two CLI shell-outs are supported:
#   responses  - OpenAI Responses API   (default; alias `openai` accepted)
#   anthropic  - Anthropic Messages API
#   codex      - shells out to `codex exec`         (only --model is honored)
#   claude     - shells out to `claude --print`     (only --model is honored)
#
# Defaults:
#   provider=responses, model=gpt-5.5
#   for anthropic/claude: model defaults to claude-opus-4-7
#
# Model is free-form: gpt-5.5, gpt-5.4, gpt-5.3-codex, deepseek-v4,
# claude-opus-4-7, claude-opus-4-6, etc. Semia does not validate it.

# SEMIA_LLM_PROVIDER=responses    # responses | anthropic | codex | claude (alias: openai)
# SEMIA_LLM_MODEL=gpt-5.5
# SEMIA_LLM_TIMEOUT=600           # request timeout (seconds)
# SEMIA_LLM_MAX_RETRIES=2         # transient-error retries per provider call

# -----------------------------------------------------------------------------
# Responses (OpenAI Responses API, also DeepSeek / vLLM / OpenRouter / etc.)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-YOUR_KEY_HERE
# OPENAI_BASE_URL=                # leave empty for https://api.openai.com/v1
# OPENAI_MODEL=                   # provider-default fallback for --model
# SEMIA_OPENAI_TEMPERATURE=
#   unset (default) = auto: send 0 for chat models (gpt-4*, gpt-3.5*), omit
#   for reasoning models (gpt-5*, o1*, o3*, o4*).
#   Set to "" to force omit, or to a number (e.g. 0.7) to force-send on any
#   model.

# -----------------------------------------------------------------------------
# Anthropic Messages API (also used as the model-name default for `claude`)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# ANTHROPIC_AUTH_TOKEN=           # alternative to ANTHROPIC_API_KEY
# ANTHROPIC_BASE_URL=             # leave empty for https://api.anthropic.com
# ANTHROPIC_MODEL=                # provider-default fallback for --model
# ANTHROPIC_VERSION=2023-06-01    # `anthropic-version` header
# SEMIA_ANTHROPIC_MAX_TOKENS=16384
# SEMIA_ANTHROPIC_THINKING_BUDGET=0  # >0 enables extended thinking

# -----------------------------------------------------------------------------
# Detector backend
# -----------------------------------------------------------------------------
# SEMIA_DETECTOR_BACKEND=auto     # auto | souffle | builtin
# SEMIA_SOUFFLE_BIN=              # path to `souffle` if not on PATH

# -----------------------------------------------------------------------------
# Synthesis loop tuning (see docs/plugin-protocol.md)
# -----------------------------------------------------------------------------
# SEMIA_SYNTHESIS_N_ITERATIONS=5
# SEMIA_SYNTHESIS_MAX_RETRIES=3
# SEMIA_SYNTHESIS_PLATEAU_MIN_IMPROVEMENT=0.01
# SEMIA_SYNTHESIS_PLATEAU_PATIENCE=3
# SEMIA_SYNTHESIS_CEILING=0.9                # stop early once composite score ≥ this
# SEMIA_SYNTHESIS_SCORE_WEIGHTS=0.5,0.3,0.2  # match_rate, support_coverage, ref_coverage
# SEMIA_SYNTHESIS_RESUME_FROM=
# SEMIA_SYNTHESIS_MAX_DOC_BYTES=2097152      # 2 MiB; raise for unusually large skills
